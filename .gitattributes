# Shell scripts must use LF — CRLF breaks them on Linux/macOS
*.sh            text eol=lf
*.sh.template   text eol=lf

# Windows batch and PowerShell files use CRLF
*.bat               text eol=crlf
*.bat.template      text eol=crlf
*.ps1               text eol=crlf
*.ps1.template      text eol=crlf

# Source and config files: normalize to LF in repo, checkout with native endings
*.java      text eol=lf
*.xml       text eol=lf
*.properties text eol=lf
*.md        text eol=lf
*.txt       text eol=lf

# Binary assets: no line-ending conversion
*.ico       binary
*.png       binary
*.jpg       binary
